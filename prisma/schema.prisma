generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Escritorio {
  id        String   @id @default(uuid())
  tenantId  String   @unique
  nome      String   @default("Meu Escritório")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Client {
  id               String   @id @default(uuid())
  tenantId         String
  nome             String
  tipo             String   @default("PF") // PF ou PJ
  documento        String // CPF ou CNPJ
  email            String?
  telefone         String?
  endereco         String?
  personalDriveUrl String?
  status           String   @default("ATIVO")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  processos  Processo[]
  transacoes Transacao[]
  documentos Documento[]

  @@unique([tenantId, documento])
  @@index([tenantId])
}

enum ProcessoStatus {
  ATIVO
  ARQUIVADO
}

enum Prioridade {
  ALTA
  MEDIA
  BAIXA
}

model Processo {
  id             String  @id @default(uuid())
  tenantId       String
  numero         String
  titulo         String
  area           String  @default("Cível")
  fase           String  @default("Conhecimento")
  prioridade     String  @default("MEDIA")
  valorCausa     Float   @default(0)
  parteAutora    String? // Nome da parte autora (polo ativo / autor)
  parteContraria String? // Nome da parte contrária (polo passivo / réu)
  polo           String  @default("ATIVO") // ATIVO (Autor/Exequente) ou PASSIVO (Réu/Executado)
  rito           String  @default("COMUM") // COMUM ou JEC (Juizado Especial Cível/Criminal)

  // --- CAMPOS DO SISTEMA ---
  dataPrazo   DateTime? // Próximo vencimento
  resultado   String? // "Procedente", "Improcedente", "Acordo"
  arquivadoEm DateTime? // Data em que o processo foi arquivado
  status      String    @default("ATIVO") // ATIVO ou ARQUIVADO

  // --- CAMPOS SINCRONIZADOS VIA CNJ ---
  tribunal         String? // Ex: "TJSP"
  orgaoJulgador    String? // Ex: "1ª Vara Cível"
  classeProcessual String? // Ex: "Procedimento Comum"
  assuntoPrincipal String? // Ex: "Concessão"
  sistema          String? // Ex: "Pje"
  dataAjuizamento  DateTime? // Data de distribuição
  sincronizadoEm   DateTime? // Última sincronização com o CNJ

  // --- CAMPO FINANCEIRO ---
  honorariosPercentual Float? // % de honorários pactuada (ex: 30.0 = 30%)

  // Relacionamentos
  clienteId     String
  cliente       Client              @relation(fields: [clienteId], references: [id])
  movimentacoes Movimentacao[]
  transacoes    Transacao[]
  historico     ProcessoHistorico[]
  documentos    Documento[]
  prazos        Prazo[]
  audiencias    Audiencia[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, numero])
  @@index([tenantId])
}

model ProcessoHistorico {
  id                String   @id @default(uuid())
  processoId        String
  tenantId          String
  acao              String // "CRIADO", "EDITADO", "STATUS_ALTERADO", "ARQUIVADO", "REABERTO", etc.
  descricao         String
  valoresAnteriores String? // Json string
  valoresNovos      String? // Json string
  createdAt         DateTime @default(now())

  processo Processo @relation(fields: [processoId], references: [id], onDelete: Cascade)

  @@index([processoId])
  @@index([tenantId])
  @@map("processo_historicos")
}

model Movimentacao {
  id         String   @id @default(uuid())
  processoId String
  codigo     Int // Código da movimentação no CNJ
  nome       String // Nome/descrição da movimentação
  dataHora   DateTime // Data e hora da movimentação

  processo Processo @relation(fields: [processoId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([processoId, codigo, dataHora]) // Evita duplicação
  @@index([processoId])
}

// === MÓDULO FINANCEIRO ===

enum TipoTransacao {
  RECEITA
  DESPESA
}

enum CategoriaTransacao {
  HONORARIOS
  CUSTAS
  REPASSE_CLIENTE
  OPERACIONAL_ESCRITORIO
}

enum StatusTransacao {
  PENDENTE
  PAGO
}

model Transacao {
  id             String             @id @default(uuid())
  tenantId       String
  tipo           TipoTransacao
  categoria      CategoriaTransacao
  valor          Float
  status         StatusTransacao    @default(PENDENTE)
  descricao      String
  dataVencimento DateTime
  dataPagamento  DateTime?
  parcelaAtual   Int?
  totalParcelas  Int?
  isFixa         Boolean            @default(false)

  processoId String?
  processo   Processo? @relation(fields: [processoId], references: [id])
  clienteId  String?
  cliente    Client?   @relation(fields: [clienteId], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? // Soft delete — preenchido no fechamento mensal

  @@index([tenantId])
  @@index([processoId])
  @@index([clienteId])
  @@index([status])
  @@index([deletedAt])
  @@map("transacoes")
}

model RelatorioMensal {
  id                   String   @id @default(uuid())
  tenantId             String
  mes                  Int // 1-12
  ano                  Int // ex: 2026
  totalReceitas        Float    @default(0)
  totalDespesas        Float    @default(0)
  totalHonorarios      Float    @default(0)
  totalCustas          Float    @default(0)
  totalRepasses        Float    @default(0)
  totalOperacional     Float    @default(0)
  quantidadeTransacoes Int      @default(0)
  saldoMes             Float    @default(0) // receitas - despesas
  fechadoEm            DateTime @default(now())

  createdAt DateTime @default(now())

  @@unique([tenantId, mes, ano])
  @@index([tenantId])
  @@map("relatorios_mensais")
}

model Documento {
  id           String   @id @default(uuid())
  tenantId     String
  nomeOriginal String
  fileKey      String
  tamanhoBytes Int
  tipoMime     String
  criadoEm     DateTime @default(now())

  // Relacionamentos opcionais: um documento pode pertencer a um Cliente ou a um Processo
  clienteId String?
  cliente   Client? @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  processoId String?
  processo   Processo? @relation(fields: [processoId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([clienteId])
  @@index([processoId])
  @@map("documentos")
}

model Prazo {
  id             String    @id @default(uuid())
  tenantId       String
  titulo         String
  descricao      String?
  dataVencimento DateTime
  concluido      Boolean   @default(false)
  dataConclusao  DateTime?
  
  processoId     String
  processo       Processo  @relation(fields: [processoId], references: [id], onDelete: Cascade)
  
  usuarioId      String?   

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([tenantId])
  @@index([processoId])
  @@index([usuarioId])
  @@map("prazos")
}

// === MÓDULO AUDIÊNCIAS ===

model Audiencia {
  id          String    @id @default(uuid())
  tenantId    String
  processoId  String
  titulo      String
  dataHora    DateTime
  local       String?
  tipo        String    @default("AUDIENCIA") // AUDIENCIA, SESSAO, OUTRO
  observacoes String?
  concluida   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  processo Processo @relation(fields: [processoId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([processoId])
  @@index([dataHora])
  @@map("audiencias")
}
